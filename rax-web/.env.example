# Public (client-safe)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-only — NEVER commit real values
SUPABASE_SERVICE_ROLE_KEY=eyJ...
ANTHROPIC_API_KEY=sk-ant-...

# Whop — subscription plans that grant credits each billing cycle.
# Each plan is a Whop subscription priced at the listed amount.
# When invoice_paid fires (initial + every renewal), we credit
# `cents` to the user. WHOP_PLAN_<cents>=<whop plan id>.
#
# Plan IDs (plan_xxxx), NOT product IDs (prod_xxxx). Hosted checkout
# (https://whop.com/checkout/{id}) routes by plan id. Find each plan id
# in the Whop dashboard → product → Pricing tab.
# API key for creating Checkout Sessions server-side (so metadata.user_id
# and redirect_url survive into the membership_activated webhook).
WHOP_API_KEY=apik_...
WHOP_WEBHOOK_SECRET=ws_...
WHOP_PLAN_20=plan_...
WHOP_PLAN_50=plan_...
WHOP_PLAN_100=plan_...
# Optional override (defaults to https://whop.com)
# WHOP_CHECKOUT_HOST=https://whop.com
